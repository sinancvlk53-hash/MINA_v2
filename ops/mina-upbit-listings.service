[Unit]
Description=MINA Upbit Listing Reporter
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/MINA_v2
ExecStart=/root/MINA_v2/venv/bin/python -u /root/MINA_v2/signal_bot/upbit_listing_watcher.py
Restart=on-failure
RestartSec=15
StandardOutput=append:/root/MINA_v2/signal_bot/upbit_listing_watcher.log
StandardError=append:/root/MINA_v2/signal_bot/upbit_listing_watcher.log

[Install]
WantedBy=multi-user.target
