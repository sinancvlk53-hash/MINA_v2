[Unit]
Description=MINA Dashboard WebSocket
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/MINA_v2
ExecStart=/root/MINA_v2/venv/bin/python -u /root/MINA_v2/dashboard/dashboard_ws.py
Restart=on-failure
RestartSec=5
StandardOutput=append:/root/MINA_v2/dashboard_ws.log
StandardError=append:/root/MINA_v2/dashboard_ws.log

[Install]
WantedBy=multi-user.target
